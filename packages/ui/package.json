{
  "name": "@flanksource/icons-ui",
  "version": "0.1.0",
  "description": "Curated UI icon set for Flanksource projects (Phosphor Light/Fill + JetBrains expui + selected alternates), generated from hack/icon-selections.json.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flanksource/flanksource-icons.git",
    "directory": "packages/ui"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "NOTICE.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts && tsx scripts/bundle.ts",
    "build:codegen": "tsx scripts/build.ts",
    "build:bundle": "tsx scripts/bundle.ts",
    "clean": "rm -rf dist src/icons src/index.ts"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "esbuild": "^0.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "svgo": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
