{
  "name": "@flanksource/icons",
  "version": "5.0.1",
  "license": "MIT",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/flanksource/icons"
  },
  "homepage": "https://github.com/react-icons/react-icons#readme",
  "peerDependencies": {
    "react": "*"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "import": "./index.mjs",
      "default": "./index.mjs"
    },
    "./lib": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "import": "./lib/index.mjs",
      "default": "./lib/index.mjs"
    },
    "./mi": {
      "types": "./mi/index.d.ts",
      "require": "./mi/index.js",
      "import": "./mi/index.mjs",
      "default": "./mi/index.mjs"
    }
  }
}
